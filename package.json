{
  "name": "ai-knowledge-base-e2e",
  "version": "1.0.0",
  "description": "AI知识库 Playwright E2E 测试",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright test --reporter=html,list",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:3000",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.10.0",
    "axios": "^1.6.2",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "automation"
  ],
  "license": "MIT"
}
