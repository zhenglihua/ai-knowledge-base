# ========================
# AI Knowledge Base v0.2.0
# Environment Variables
# ========================

# --- Application ---
ENVIRONMENT=production
SECRET_KEY=your-256-bit-secret-key-here-change-in-production

# --- Database ---
DATABASE_URL=postgresql://aikb_user:aikb_password@postgres:5432/aikb_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# --- JWT Auth ---
JWT_SECRET=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Qdrant Vector DB ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- Service Ports ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- NRE Service (Optional) ---
NRE_API_URL=http://nre-service:8001
NRE_API_KEY=your-nre-api-key

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=/var/log/aikb/app.log
