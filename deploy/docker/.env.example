# CIMBrain 私有化部署配置
# 复制此文件为 .env 并修改配置

# ========== 数据库配置 ==========
POSTGRES_PASSWORD=cimbrain_secure_password_2024

# ========== MinIO 对象存储 ==========
MINIO_ACCESS_KEY=cimbrain_minio_key
MINIO_SECRET_KEY=cimbrain_minio_secret_change_me

# ========== LLM 配置 ==========
# 可选: ollama / qwen / openai / minimax
LLM_PROVIDER=ollama

# Ollama 配置 (本地模型)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# 通义千问配置 (云端模型)
# QWEN_API_KEY=your_api_key_here
# QWEN_MODEL=qwen-turbo

# ========== 端口配置 (可选) ==========
# 默认端口已在 docker-compose.yml 中配置
# 如需修改，请同时更新 docker-compose.yml
